# Anthropic API key used by the LLM triager / PoC generator stages
ANTHROPIC_API_KEY=sk-ant-...

# --- Optional tuning (defaults shown) ---

# Path to the SQLite database
# HUNTER_DB_PATH=./hunter.db

# Stop triaging once this much has been spent today (USD). Unset = no cap.
# HUNTER_DAILY_BUDGET_USD=

# Parallel triage workers (1 = serial; 2-3 is usually safe)
# HUNTER_TRIAGE_CONCURRENCY=1

# Claude Code-based triager tuning (if using cc_triager)
# HUNTER_CC_TRIAGE_CONCURRENCY=1
# HUNTER_CC_TIMEOUT_SEC=240
